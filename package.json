{
  "name": "chess-academy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An open-source chess study tool with guided lessons, a glossary, classic strategy study, and future puzzle training.",
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/vendor-engine.mjs",
    "vendor-engine": "node scripts/vendor-engine.mjs",
    "predev": "node scripts/vendor-engine.mjs",
    "dev": "vite",
    "prebuild": "node scripts/vendor-engine.mjs",
    "build": "vite build",
    "lint": "eslint . --ext .js,.jsx,.mjs,.cjs --max-warnings=0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate-content": "node scripts/validate-content.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "chess.js": "^1.4.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.3",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.35",
    "stockfish.js": "^10.0.2",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.6",
    "vitest": "^1.6.0"
  }
}
